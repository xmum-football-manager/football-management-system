# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real keys.

# Supabase project URL (dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key — RLS-enforced, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — bypasses RLS. Server-only. NEVER send to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL the app uses to construct absolute links (invite emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Root domain for subdomain-based routing (admin.<root>, score.<root>) handled by proxy.ts
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# Sentry DSN — optional locally; required in production
NEXT_PUBLIC_SENTRY_DSN=

# Use mock tournament data for local dev (no Supabase connection needed)
NEXT_PUBLIC_USE_MOCK_DATA=false
